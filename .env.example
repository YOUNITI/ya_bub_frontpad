# ============================================
# Ya-Budu Production Configuration Example
# ============================================
# Скопируйте этот файл как .env и заполните реальными значениями

# ------------------------------------------------
# Frontend Environment Variables (Vite)
# ------------------------------------------------
VITE_API_URL=https://ябуду.com
VITE_WS_URL=wss://ябуду.com

# ------------------------------------------------
# Server Environment Variables (Node.js)
# ------------------------------------------------

# URL сайта (для синхронизации и генерации чеков)
SITE_URL=https://ябуду.com

# JWT Secret для аутентификации (придумайте сложный ключ)
JWT_SECRET=CHANGE_ME_IN_PRODUCTION

# Порт сервера (по умолчанию 3001)
PORT=3001

# URL Frontpad (админ-панель)
FRONTPAD_URL=http://localhost:3005

# Токены синхронизации между сайтом и Frontpad (измените!)
FRONTPAD_SYNC_TOKEN=CHANGE_ME
SITE_SYNC_TOKEN=CHANGE_ME

# ------------------------------------------------
# SMTP настройки для отправки email уведомлений
# ------------------------------------------------
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your-email@yandex.ru
SMTP_PASS=your-app-password
ADMIN_EMAIL=admin@example.com

# ------------------------------------------------
# Frontpad Server Variables
# ------------------------------------------------
FRONTPAD_PORT=3005

# ------------------------------------------------
# MySQL Database Configuration
# ------------------------------------------------
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=CHANGE_ME
DB_NAME=yabudu_main

# Опционально: имя базы данных Frontpad (если используется отдельная)
# FRONTPAD_DB_NAME=yabudu_frontpad
