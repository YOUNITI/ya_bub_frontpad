# ============================================
# Ya-Budu Configuration File
# ============================================
# Копируйте этот файл в .env и заполните значениями
# ============================================

# ------------------------------------------------
# Frontend Environment Variables (Vite)
# ------------------------------------------------
# API URL для подключения из браузера
VITE_API_URL=http://localhost:3001
# WebSocket URL для подключения из браузера  
VITE_WS_URL=ws://localhost:3005

# ------------------------------------------------
# Server Environment Variables (Node.js)
# ------------------------------------------------

# URL сайта (для синхронизации и генерации чеков)
SITE_URL=http://localhost:3001

# JWT Secret для аутентификации
JWT_SECRET=your-jwt-secret-key-here

# Токены синхронизации между сайтом и Frontpad
# Эти токены должны совпадать на обоих серверах
FRONTPAD_SYNC_TOKEN=change-sync-token-in-production
SITE_SYNC_TOKEN=change-sync-token-in-production

# Порт сервера (по умолчанию 3001)
PORT=3001

# URL YounitiPad API (для синхронизации заказов)
# На локальном: http://localhost:3005
# На сервере: http://localhost:3005
FRONTPAD_URL=http://localhost:3005

# ------------------------------------------------
# SMTP настройки для отправки email уведомлений
# ------------------------------------------------
# Пример для Яндекс.Почты:
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your-email@yandex.ru
SMTP_PASS=your-app-password

# Email администратора для уведомлений о новых заказах
ADMIN_EMAIL=admin@xn--90ag8bb0d.com

# ------------------------------------------------
# YounitiPad Server Variables
# ------------------------------------------------
# Порт YounitiPad API (по умолчанию 3005)
FRONTPAD_PORT=3005

# ------------------------------------------------
# MySQL Database Configuration (опционально)
# ------------------------------------------------
# Если DB_TYPE=mysql, будет использоваться MySQL вместо SQLite
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=123456
# DB_NAME=yabudu_main
