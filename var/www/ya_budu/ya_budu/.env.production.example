# ============================================
# Ya-Budu Production Configuration
# ============================================
# Копируйте этот файл в .env и заполните реальными значениями

# ------------------------------------------------
# Frontend Environment Variables (Vite)
# ------------------------------------------------
# URL вашего сайта в продакшене
VITE_API_URL=https://your-domain.com
VITE_WS_URL=wss://your-domain.com/ws

# ------------------------------------------------
# Server Environment Variables (Node.js)
# ------------------------------------------------

# URL сайта (для синхронизации и генерации чеков)
SITE_URL=https://your-domain.com

# JWT Secret - СГЕНЕРИРУЙТЕ СЛОЖНЫЙ СЛУЧАЙНЫЙ КЛЮЧ!
JWT_SECRET=CHANGE_THIS_TO_RANDOM_SECRET_KEY_MIN_32_CHARS

# Порт сервера
PORT=3001

# URL Frontpad (админ-панель)
FRONTPAD_URL=https://fp.your-domain.com

# Токены синхронизации между сайтом и Frontpad
# Эти токены ДОЛЖНЫ совпадать на обоих серверах!
FRONTPAD_SYNC_TOKEN=CHANGE_TO_RANDOM_SYNC_TOKEN
SITE_SYNC_TOKEN=CHANGE_TO_RANDOM_SYNC_TOKEN

# ------------------------------------------------
# SMTP настройки для отправки email уведомлений
# ------------------------------------------------
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your-email@your-domain.com
SMTP_PASS=your-app-password
ADMIN_EMAIL=admin@your-domain.com

# ------------------------------------------------
# Frontpad Server Variables
# ------------------------------------------------
FRONTPAD_PORT=3005

# ------------------------------------------------
# MySQL Database Configuration
# ------------------------------------------------
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=yabudu_main

# Опционально: имя базы данных Frontpad (если используется отдельная)
# FRONTPAD_DB_NAME=yabudu_frontpad
